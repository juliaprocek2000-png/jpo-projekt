{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Kompiluj Projekt Bielik",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/src/*.cpp",
                "-o",
                "${workspaceFolder}/src/analizator.exe",
                "-I", "${workspaceFolder}/include"
            ],
            "options": {
                "cwd": "C:/msys64/mingw64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "default": true
            },
            "detail": "Kompilacja wszystkich plików .cpp w folderze src"
        }
    ]
}